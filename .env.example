# Anthropic API（Phase 4 评论摘要必需）
ANTHROPIC_API_KEY=sk-ant-xxx

# eBay Developer App ID（Phase 2 必需）
# 注册地址 https://developer.ebay.com/
EBAY_APP_ID=
EBAY_CERT_ID=

# 可选 HTTP 代理（Amazon/Walmart 大量请求时建议配置）
HTTP_PROXY=
HTTPS_PROXY=

# 抓取参数
TOP_N_PER_QUERY=50
REVIEW_TOP_N=20
REQUEST_DELAY_MIN=3
REQUEST_DELAY_MAX=8
